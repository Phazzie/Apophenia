/*
  # Security Headers
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()
  
  # Content Security Policy
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://generativelanguage.googleapis.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https: blob:; font-src 'self' data:; connect-src 'self' https://generativelanguage.googleapis.com https://api.x.ai https://*.supabase.co wss://*.supabase.co; frame-ancestors 'none'; base-uri 'self'; form-action 'self';
  
  # Cache Control
  Cache-Control: public, max-age=31536000, immutable

/*.html
  # HTML files should not be cached
  Cache-Control: no-cache, no-store, must-revalidate

/*.json
  # JSON files can be cached for a shorter time
  Cache-Control: public, max-age=3600

/manifest.json
  # Manifest should be cached longer
  Cache-Control: public, max-age=86400
