{
  "name": "apophenia-cosmic-narrative",
  "version": 2,
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "devCommand": "npm run dev",
  "env": {
    "VITE_XAI_API_KEY": "@vite-xai-api-key"
  },
  "build": {
    "env": {
      "VITE_XAI_API_KEY": "@vite-xai-api-key"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}