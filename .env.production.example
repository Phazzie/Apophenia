# Production Environment Configuration for Apophenia

# Google Gemini AI API Key (required for story generation)
VITE_GEMINI_API_KEY=your-production-google-gemini-api-key

# Google Imagen API Key (optional - for image generation)
VITE_GOOGLE_IMAGEN_KEY=your-production-google-imagen-api-key

# Production deployment settings
NODE_ENV=production
VITE_APP_ENV=production

# Performance settings
VITE_ENABLE_PRELOAD=true
VITE_ENABLE_COMPRESSION=true

# Error tracking (optional)
# VITE_SENTRY_DSN=your-sentry-dsn-for-error-tracking

# Analytics (optional)
# VITE_GA_TRACKING_ID=your-google-analytics-id