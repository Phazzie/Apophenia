# Production Environment Configuration for Apophenia

# Google Gemini API Key (required for primary image generation via Imagen 3.0)
VITE_GEMINI_API_KEY=your-production-gemini-api-key

# X.AI Grok API Key (required for story generation and fallback image generation)
VITE_XAI_API_KEY=your-production-xai-api-key

# Production deployment settings
NODE_ENV=production
VITE_APP_ENV=production

# Performance settings
VITE_ENABLE_PRELOAD=true
VITE_ENABLE_COMPRESSION=true

# Error tracking (optional)
# VITE_SENTRY_DSN=your-sentry-dsn-for-error-tracking

# Analytics (optional)
# VITE_GA_TRACKING_ID=your-google-analytics-id