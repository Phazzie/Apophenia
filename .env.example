# Google Gemini AI for story generation and image generation (fallback)
VITE_GEMINI_API_KEY=your-google-gemini-api-key-here

# X.AI Grok-4 Fast Reasoning AI (primary model)
VITE_XAI_API_KEY=your-xai-api-key-here

# Backend API keys (for server-side API calls)
GEMINI_API_KEY=your-google-gemini-api-key-here
XAI_API_KEY=your-xai-api-key-here

# Cache Configuration
VITE_IMAGE_CACHE_TTL=1800000
VITE_IMAGE_CACHE_MAX_SIZE=50
VITE_ENABLE_CACHE_TELEMETRY=true
