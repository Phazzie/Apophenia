{
  "name": "apophenia-cosmic-narrative",
  "version": "1.0.0",
  "private": true,
  "description": "An AI-driven interactive cosmic horror narrative game",
  "keywords": [
    "ai",
    "interactive-fiction",
    "horror",
    "narrative",
    "game",
    "react"
  ],
  "author": "Phazzie",
  "repository": {
    "type": "git",
    "url": "https://github.com/Phazzie/Apophenia.git"
  },
  "homepage": "https://apophenia-cosmic-narrative.vercel.app",
  "type": "module",
  "scripts": {
    "dev": "npx vite",
    "build": "npx tsc && npx vite build",
    "preview": "npx vite preview",
    "test": "npx vitest",
    "test:watch": "npx vitest --watch",
    "lint": "npx eslint . --ext .ts,.tsx --report-unused-disable-directives --max-warnings 0",
    "format": "npx prettier --write .",
    "deploy": "npm run build",
    "deploy:gh-pages": "npm run build && npx gh-pages -d dist",
    "deploy:netlify": "npm run build && echo 'Upload dist/ folder to Netlify'",
    "start": "npm run dev",
    "server": "node server.js",
    "server:dev": "npx nodemon server.js",
    "fullstack:dev": "npx concurrently \"npm run server:dev\" \"npm run dev\"",
    "build:all": "npm run build && echo 'Frontend built. Deploy server.js separately for backend.'",
    "start:prod": "node server.js"
  },
  "dependencies": {
    "@genkit-ai/googleai": "^1.16.1",
    "@google-ai/generativelanguage": "^3.4.0",
    "@google/generative-ai": "^0.24.1",
    "@supabase/supabase-js": "^2.76.1",
    "@vitest/ui": "^3.2.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "firebase-admin": "^13.5.0",
    "genkit": "^1.16.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vercel": "^48.5.0",
    "zod": "^4.1.12",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@eslint/compat": "^1.4.0",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.9.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.45.0",
    "@typescript-eslint/parser": "^8.45.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^8.2.2",
    "cross-env": "^10.1.0",
    "eslint": "^9.36.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.22",
    "gh-pages": "^6.1.1",
    "globals": "^16.4.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.1.3",
    "jest-environment-jsdom": "^30.0.5",
    "nodemon": "^3.0.1",
    "prettier": "^3.3.2",
    "ts-jest": "^29.4.4",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.45.0",
    "vite": "^7.1.5",
    "vitest": "^3.2.4",
    "whatwg-fetch": "^3.6.20"
  },
  "engines": {
    "node": "20.19.0 || 22.12.0"
  }
}
