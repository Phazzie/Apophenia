{
  "name": "apophenia-cosmic-narrative",
  "version": 2,
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "devCommand": "npm run dev",
  "env": {
    "VITE_GEMINI_API_KEY": "@vite-gemini-api-key"
  },
  "build": {
    "env": {
      "VITE_GEMINI_API_KEY": "@vite-gemini-api-key"
    }
  },
  "functions": {},
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}