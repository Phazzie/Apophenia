{
  "name": "apophenia-cosmic-narrative",
  "version": "1.0.0",
  "private": true,
  "description": "An AI-driven interactive cosmic horror narrative game",
  "keywords": [
    "ai",
    "interactive-fiction",
    "horror",
    "narrative",
    "game",
    "react"
  ],
  "author": "Phazzie",
  "repository": {
    "type": "git",
    "url": "https://github.com/Phazzie/Apophenia.git"
  },
  "homepage": "https://apophenia-cosmic-narrative.vercel.app",
  "scripts": {
    "dev": "./node_modules/.bin/vite",
    "build": "./node_modules/.bin/tsc && ./node_modules/.bin/vite build",
    "preview": "./node_modules/.bin/vite preview",
    "test": "jest",
    "test:coverage": "COVERAGE=true jest --coverage",
    "test:mutation": "npx stryker run",
    "test:e2e": "playwright test",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint src --ext ts,tsx --fix",
    "check:features": "node scripts/check-features.js",
    "verify:changelog": "node scripts/verify-changelog.js",
    "ai:review": "node scripts/ai-reviewer.js",
    "verify": "npm run test:coverage && npm run check:features && npm run verify:changelog",
    "deploy": "npm run build && vercel --prod",
    "deploy:gh-pages": "npm run build && npx gh-pages -d dist",
    "deploy:netlify": "npm run build && echo 'Upload dist/ folder to Netlify'",
    "start": "npm run dev",
    "server": "node server.js",
    "server:dev": "nodemon server.js",
    "fullstack:dev": "concurrently \"npm run server:dev\" \"npm run dev\"",
    "build:all": "npm run build && echo 'Frontend built. Deploy server.js separately for backend.'",
    "start:prod": "node server.js"
  },
  "dependencies": {
    "@genkit-ai/googleai": "^1.16.1",
    "@google-ai/generativelanguage": "^3.4.0",
    "@google/generative-ai": "^0.24.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "genkit": "^1.16.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.1",
    "@stryker-mutator/core": "^9.1.1",
    "@stryker-mutator/jest-runner": "^9.1.1",
    "@stryker-mutator/typescript-checker": "^9.1.1",
    "@testing-library/jest-dom": "^6.4.0",
    "@types/jest": "^30.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.44.1",
    "@typescript-eslint/parser": "^8.44.1",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.21",
    "gh-pages": "^6.1.1",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.1.3",
    "jest-environment-jsdom": "^30.0.5",
    "nodemon": "^3.0.1",
    "playwright": "^1.55.1",
    "ts-jest": "^29.4.4",
    "typescript": "^5.4.5",
    "vite": "^7.1.5",
    "whatwg-fetch": "^3.6.20"
  }
}
