# Google Gemini API (required for image generation - fallback to Grok if not configured; primary image generation via Gemini 2.5 Flash Image)
VITE_GEMINI_API_KEY=your-gemini-api-key-here

# X.AI Grok-4 Fast Reasoning AI (story generation and fallback images)
VITE_XAI_API_KEY=your-xai-api-key-here

# Backend API keys (for server-side API calls)
XAI_API_KEY=your-xai-api-key-here

# Cache Configuration
VITE_IMAGE_CACHE_TTL=1800000
VITE_IMAGE_CACHE_MAX_SIZE=50
VITE_ENABLE_CACHE_TELEMETRY=true
