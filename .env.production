# Production environment variables for Apophenia
# These will be injected by the deployment platform

# AI Service Configuration
VITE_GEMINI_API_KEY=
VITE_GOOGLE_NANO_BANANA_KEY=
VITE_GOOGLE_IMAGEN_KEY=

# Application Configuration
VITE_APP_TITLE=Apophenia
