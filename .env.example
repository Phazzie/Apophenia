# This file contains environment variables needed to run the application's AI features.
# Copy this file to a new file named .env and fill in the values.

# Option 1: Use an API Key (suitable for client-side or simple server-side use)
# Get this from your Google Cloud project credentials page.
# GOOGLE_API_KEY=your-google-api-key-here

# Option 2: Use a Service Account (recommended for server-side deployment)
# Set this to the path of your JSON credentials file.
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/service-account-file.json
